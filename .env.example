# Copy to .env and fill in your key:
#   cp .env.example .env
#
# Get a free OpenRouter key: https://openrouter.ai/keys
# (account is free; free models have rate limits)

PROVIDER=openrouter
OPENROUTER_API_KEY=sk-or-v1-...

# Free model router (auto-picks free models that support tools)
MODEL=openrouter/free

# Or pin a free coding model:
# MODEL=qwen/qwen3-coder:free
# MODEL=poolside/laguna-xs-2.1:free
# MODEL=poolside/laguna-m.1:free
# MODEL=openai/gpt-oss-120b:free
# MODEL=meta-llama/llama-3.3-70b-instruct:free
# MODEL=tencent/hy3:free
