# mini-pi needs an OpenAI-compatible *API*, not a chat subscription.
#
# SuperGrok / ChatGPT Plus / Codex sub ≠ API key for this project.
# Codex CLI already works via `codex` with ChatGPT login — use that for
# day-to-day coding; use mini-pi when you want to study the harness.

# ── Option A: Ollama (free, local) ─────────────────────────────
# PROVIDER=ollama
# MODEL=llama3.2
# OLLAMA_HOST=http://127.0.0.1:11434

# ── Option B: OpenRouter ───────────────────────────────────────
# OPENROUTER_API_KEY=sk-or-...
# MODEL=openai/gpt-4o-mini

# ── Option C: OpenAI platform API (pay-per-token; ≠ ChatGPT sub)
# OPENAI_API_KEY=sk-...
# MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# ── Option D: xAI API (≠ SuperGrok subscription) ───────────────
# XAI_API_KEY=xai-...
# MODEL=grok-4.5
